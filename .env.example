# ─── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_TTS_VOICE=Puck
# USE_GEMINI_REALTIME=true   # default is true; set to false to disable realtime

# ─── Vobiz SIP Trunk ──────────────────────────────────────────────────────────
VOBIZ_SIP_TRUNK_ID=ST_xxxxxxxxxxxxxxxxxxxx
VOBIZ_SIP_DOMAIN=sip.vobiz.in
VOBIZ_USERNAME=your_sip_username
VOBIZ_PASSWORD=your_sip_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# ─── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ─── Cal.com (optional) ────────────────────────────────────────────────────────
CALCOM_API_KEY=your_calcom_api_key
CALCOM_EVENT_TYPE_ID=123456

# ─── AWS S3 / Compatible (call recordings) ────────────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=aiona-recordings
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=ap-south-1

# ─── App ───────────────────────────────────────────────────────────────────────
API_PORT=8000
API_SECRET=change_me_strong_random_string
